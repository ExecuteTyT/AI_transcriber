# === Database ===
DATABASE_URL=postgresql+asyncpg://aivoice:aivoice@db:5432/aivoice
POSTGRES_USER=aivoice
POSTGRES_PASSWORD=aivoice
POSTGRES_DB=aivoice

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
# Production-guard в config.py упадёт при старте если значение = "change-me-in-production".
# Сгенерируй: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Mistral AI — транскрибация (Voxtral) + embeddings (mistral-embed) ===
MISTRAL_API_KEY=your-mistral-api-key
TRANSCRIPTION_PROVIDER=voxtral

# === Google Gemini (LLM — summaries, RAG chat answers) ===
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# === S3 (Selectel) — оставь пустым для локального хранилища ===
S3_ENDPOINT_URL=https://s3.storage.selcloud.ru
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=aivoice-files
S3_REGION=ru-1
LOCAL_STORAGE_PATH=./data/uploads

# === YooKassa ===
# 🚨 ЕДИНСТВЕННОЕ ЧТО НУЖНО ЗАПОЛНИТЬ ВРУЧНУЮ ПЕРЕД ДЕПЛОЕМ:
# Получаются после подписания договора с ЮKassa и активации магазина.
# Без них /api/payments/* возвращает 503/500 — остальной сервис работает.
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=your-webhook-secret

# === SMTP (email) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=noreply@aivoice.ru
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@aivoice.ru
SMTP_FROM_NAME=AI Voice
SMTP_USE_TLS=true
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# === App ===
APP_URL=http://localhost:3000      # prod: https://dicto.pro
API_URL=http://localhost:8000      # prod: https://dicto.pro
# Доп. CORS origins через запятую. Только https:// (или localhost). См. main.py:_validate_origin
CORS_EXTRA_ORIGINS=
ENVIRONMENT=development  # development, staging, production

# === 152-ФЗ: compliance settings ===
# Версия политики конфиденциальности — пишется в user_consents.policy_version.
# Меняется при существенной правке текста /privacy.
POLICY_VERSION=2026-05-01
# Срок хранения аудиофайла по умолчанию (1-30 дней). Применяется к новым
# транскрипциям, если у пользователя не задан default_audio_retention_days.
AUDIO_RETENTION_DEFAULT_DAYS=7
# Путь к audit-журналу (152-ФЗ — журнал учёта действий с ПДн).
# В docker-compose.prod.yml volume audit_logs смонтирован в этот путь.
AUDIT_LOG_PATH=/var/log/dicto/audit.log

# === Grafana (optional) ===
GRAFANA_PASSWORD=change-me-in-production
